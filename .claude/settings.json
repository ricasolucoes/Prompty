{
  "includeCoAuthoredBy": false,

  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git tag:*)",
      "Bash(git push:*)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)"
    ],
    "defaultMode": "bypassPermissions",
    "deny": [],
    "ask": [
      "Bash(git reset:*)",
      "Bash(git push --force:*)"
    ]
  }
}
