# Supabase — Promptys
# Copie este arquivo para .env e preencha os valores.
# Obtenha as chaves em: https://supabase.com/dashboard/project/<ref>/settings/api

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...   # NUNCA expor no frontend — apenas server/CLI

# Usado pelo Supabase CLI e ferramentas de migração (nunca expor no frontend)
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=<project-ref>
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
